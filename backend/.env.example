# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_parking
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Server
PORT=8080

# MQTT Broker (Eclipse Mosquitto)
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=smart-parking-backend
# Untuk Wokwi (cloud), gunakan: tcp://broker.hivemq.com:1883

# Midtrans Payment Gateway
# Daftar di: https://sandbox.midtrans.com
# Settings → Access Keys → Server Key
MIDTRANS_SERVER_KEY=your-midtrans-server-key-sandbox
MIDTRANS_CLIENT_KEY=your-midtrans-client-key-sandbox
MIDTRANS_SANDBOX=true
# Jika kosong / default value → sistem berjalan dalam mode simulator

# OCR Service
OCR_SERVICE_URL=http://localhost:8000
